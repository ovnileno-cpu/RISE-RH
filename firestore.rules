// ===============================================================
// Assumed Data Model
// ===============================================================
// Collection: users
// Document ID: {userId}
// Fields: uid, email, displayName, role, department, createdAt
//
// Collection: employees
// Document ID: {employeeId}
// Fields: uid, firstName, lastName, cin, address, phone, contractType, startDate, department, position, baseSalary, managerId, status
//
// Collection: leaves
// Document ID: {leaveId}
// Fields: employeeId, type, startDate, endDate, status, reason, createdAt
//
// Collection: payrolls
// Document ID: {payrollId}
// Fields: employeeId, month, year, baseSalary, cnapsEmployee, cnapsEmployer, osiemEmployee, osiemEmployer, irsa, netSalary, createdAt
//
// Collection: jobOffers
// Document ID: {jobOfferId}
// Fields: title, department, location, contractType, description, status, createdAt
//
// Collection: candidates
// Document ID: {candidateId}
// Fields: jobOfferId, firstName, lastName, email, status, notes, createdAt
//
// Collection: trainings
// Document ID: {trainingId}
// Fields: title, department, budget, status
//
// Collection: evaluations
// Document ID: {evaluationId}
// Fields: employeeId, managerId, campaign, score, comments, date
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedUser() {
      // In this specific app, we might not strictly require verified emails yet
      // but it's a good practice. Removing strict check for now to avoid blocking users.
      return isSignedIn();
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (getUserData().role == 'admin' || request.auth.token.email == 'ovnileno@gmail.com');
    }

    function isManager() {
      let data = getUserData();
      return isSignedIn() && (data.role == 'manager' || data.role == 'admin' || request.auth.token.email == 'ovnileno@gmail.com');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Validation Functions
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.email is string && data.email.size() <= 100 &&
             data.role in ['admin', 'manager', 'employee'] &&
             (data.get('displayName', '') is string) &&
             (data.get('department', '') is string);
    }

    function isValidLeave(data) {
      return data.keys().hasAll(['employeeId', 'type', 'startDate', 'endDate', 'status']) &&
             data.type in ['annuel', 'maladie', 'maternite', 'paternite', 'sans_solde'] &&
             data.startDate is string && data.endDate is string &&
             data.status in ['pending', 'approved_manager', 'approved_rh', 'rejected'] &&
             data.get('reason', '').size() <= 500;
    }

    function isValidEmployee(data) {
      return data.keys().hasAll(['uid', 'firstName', 'lastName', 'contractType', 'baseSalary']) &&
             data.uid is string && data.uid.size() <= 64 &&
             data.firstName is string && data.firstName.size() <= 50 &&
             data.lastName is string && data.lastName.size() <= 50 &&
             data.contractType in ['CDI', 'CDD', 'Stage'] &&
             data.baseSalary is number;
    }

    // --- Collections ---

    // Users Collection
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if (isOwner(userId) || isAdmin()) && isValidUser(incoming());
      allow update: if (isOwner(userId) || isAdmin()) && 
                    (isAdmin() || (incoming().uid == existing().uid && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'department'])));
      allow delete: if isAdmin();
    }
    
    // Employees Collection
    match /employees/{employeeId} {
      allow get: if isSignedIn(); // Basic info needs to be readable for mentions/colleagues
      allow list: if isAdmin() || isManager();
      allow create: if isAdmin() && isValidEmployee(incoming());
      allow update: if isAdmin() || 
                    (isOwner(existing().uid) && incoming().diff(existing()).affectedKeys().hasOnly(['address', 'phone']));
      allow delete: if isAdmin();
    }
    
    // Leaves Collection
    match /leaves/{leaveId} {
      allow get: if isSignedIn() && (isAdmin() || isManager() || isOwner(existing().employeeId));
      allow list: if isSignedIn() && (isAdmin() || isManager() || resource.data.employeeId == request.auth.uid);
      allow create: if isVerifiedUser() && isValidLeave(incoming()) && incoming().status == 'pending';
      allow update: if isVerifiedUser() && (
        isAdmin() || 
        isManager() || 
        (isOwner(existing().employeeId) && existing().status == 'pending' && incoming().diff(existing()).affectedKeys().hasOnly(['startDate', 'endDate', 'reason', 'type']))
      );
      allow delete: if isAdmin() || (isOwner(existing().employeeId) && existing().status == 'pending');
    }
    
    // Payrolls Collection
    match /payrolls/{payrollId} {
      allow get: if isSignedIn() && (isAdmin() || isOwner(existing().employeeId));
      allow list: if isSignedIn() && (isAdmin() || resource.data.employeeId == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }
    
    // Job Offers Collection
    match /jobOffers/{jobOfferId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isManager();
    }
    
    // Candidates Collection
    match /candidates/{candidateId} {
      allow read: if isManager();
      allow create, update, delete: if isManager();
    }
    
    // Trainings Collection
    match /trainings/{trainingId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isManager();
    }
    
    // Evaluations Collection
    match /evaluations/{evaluationId} {
      allow get: if isSignedIn() && (isAdmin() || isManager() || isOwner(existing().employeeId));
      allow list: if isSignedIn() && (isAdmin() || isManager() || resource.data.employeeId == request.auth.uid);
      allow create, update, delete: if isManager();
    }
    
    // Onboarding Tasks Collection
    match /onboardingTasks/{taskId} {
      allow get: if isSignedIn() && (isAdmin() || isManager() || isOwner(existing().employeeId));
      allow list: if isSignedIn() && (isAdmin() || isManager() || resource.data.employeeId == request.auth.uid);
      allow create: if isManager();
      allow update: if isSignedIn() && (isManager() || (isOwner(existing().employeeId) && incoming().diff(existing()).affectedKeys().hasOnly(['isCompleted', 'completedAt'])));
      allow delete: if isManager();
    }

    // User Progress Collection
    match /userProgress/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['completedTutorials']);
      allow delete: if isAdmin();
    }
  }
}
